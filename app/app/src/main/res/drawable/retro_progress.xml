<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Background -->
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="4dp" />
            <solid android:color="@color/retro_dark_blue" />
            <stroke
                android:width="1dp"
                android:color="@color/retro_gray" />
        </shape>
    </item>
    
    <!-- Secondary Progress -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <corners android:radius="4dp" />
                <solid android:color="@color/retro_pink" />
            </shape>
        </clip>
    </item>
    
    <!-- Progress -->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="4dp" />
                <gradient
                    android:angle="0"
                    android:endColor="@color/retro_cyan"
                    android:startColor="@color/retro_green" />
            </shape>
        </clip>
    </item>
    
</layer-list>