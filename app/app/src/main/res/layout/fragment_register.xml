<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/retro_computer"
        android:text="CREATE ACCOUNT"
        android:textColor="@color/retro_cyan"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/usernameLayout"
        android:textColorHint="@color/retro_gray"
        app:startIconDrawable="@drawable/ic_person"
        app:startIconTint="@color/retro_cyan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/RetroTextInput"
        app:boxStrokeColor="@color/retro_cyan"
        app:hintTextColor="@color/retro_pink"
        app:errorTextColor="@color/retro_red">


        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/usernameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/retro_computer"
            android:inputType="textPersonName"
            android:textColor="@color/retro_white"
            android:hint="Username"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Password"
        android:textColorHint="@color/retro_gray"
        app:boxStrokeColor="@color/retro_cyan"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/retro_cyan"
        app:hintTextColor="@color/retro_cyan"
        app:startIconDrawable="@drawable/ic_lock"
        app:startIconTint="@color/retro_cyan">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/retro_computer"
            android:inputType="textPassword"
            android:textColor="@color/retro_white"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/confirmPasswordLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="Confirm Password"
        android:textColorHint="@color/retro_gray"
        app:boxStrokeColor="@color/retro_cyan"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/retro_cyan"
        app:hintTextColor="@color/retro_cyan"
        app:startIconDrawable="@drawable/ic_lock"
        app:startIconTint="@color/retro_cyan">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/confirmPasswordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/retro_computer"
            android:inputType="textPassword"
            android:textColor="@color/retro_white"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/registerButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/retro_pink"
        android:fontFamily="@font/retro_computer"
        android:text="REGISTER"
        android:textColor="@color/retro_white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? "
            android:textColor="@color/retro_light_gray"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/loginLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOGIN"
            android:textColor="@color/retro_pink"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="24dp"
        android:indeterminateTint="@color/retro_cyan"
        android:visibility="gone" />

    </LinearLayout>

</ScrollView>
